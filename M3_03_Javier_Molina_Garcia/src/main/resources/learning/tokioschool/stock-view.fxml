<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="learning.tokioschool.StockController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox spacing="15.0" prefWidth="250.0">
        <VBox spacing="5.0">
            <Label text="Identificador" />
            <TextField fx:id="txtId" promptText="Ej: P001" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Nombre Producto" />
            <TextField fx:id="txtNombre" promptText="Ej: Teclado Mecánico" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Stock" />
            <TextField fx:id="txtStock" promptText="Ej: 50" />
        </VBox>

        <HBox spacing="15.0">
            <padding>
                <Insets top="10.0" />
            </padding>
            <Button text="Agregar" onAction="#agregarProducto" prefWidth="90.0" />
            <Button text="Modificar" onAction="#modificarProducto" prefWidth="90.0" />
        </HBox>
    </VBox>

    <TableView fx:id="tablaProductos" HBox.hgrow="ALWAYS" prefWidth="450.0">
        <columns>
            <TableColumn fx:id="colId" text="Identificador" prefWidth="120.0" />
            <TableColumn fx:id="colNombre" text="Nom. Producto" prefWidth="220.0" />
            <TableColumn fx:id="colStock" text="Stock" prefWidth="100.0" />
        </columns>
    </TableView>

</HBox>